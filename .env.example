# GitLab 地址，不要带 /api/v4
GITLAB_BASE_URL=https://gitlab.example.com
# 建议使用专门 bot 用户生成的 Personal Access Token（scope: api）
GITLAB_TOKEN=your_gitlab_token
# 需要与 GitLab Webhook 页面的 Secret Token 完全一致
GITLAB_WEBHOOK_SECRET=your_webhook_secret

# OpenAI 或兼容 OpenAI 协议的模型网关地址
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-5.4

# 其余运行参数已内置默认值，普通部署场景无需配置：
# - 手动触发用户名会自动使用 GITLAB_TOKEN 对应的 GitLab 用户名
# - OPENAI_API_STYLE 默认 chat_completions
# - OPENAI_STRUCTURED_OUTPUT_MODE 默认 json_schema
# - PROMPT_DIR 默认 prompts
# - REQUEST_TIMEOUT_SECONDS 默认 120
